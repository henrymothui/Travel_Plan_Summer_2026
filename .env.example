# Shared itinerary (Upstash Redis / Vercel KV)
# Required on Vercel for add/edit/delete to persist for everyone.
# After connecting Upstash in the Vercel dashboard, these are usually injected automatically.
# Locally, if these are unset, edits are saved to data/itinerary.local.json instead.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Or use Upstash's native names instead:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Unlock PIN required to add/edit the shared itinerary
EDIT_PIN=change-me

# Random secret used to sign the unlock session cookie (use a long random string)
SESSION_SECRET=replace-with-a-long-random-string
