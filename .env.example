# Shared trips + itineraries (Upstash Redis / Vercel KV)
# Required on Vercel for create/edit/delete to persist for everyone.
# After connecting Upstash in the Vercel dashboard, these are usually injected automatically.
# Locally, if these are unset, data is saved to data/trips.local.json instead
# (existing data/itinerary.local.json is migrated automatically on first load).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Or use Upstash's native names instead:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Unlock PIN required to add/edit trips and itineraries
EDIT_PIN=change-me

# Random secret used to sign the unlock session cookie (use a long random string)
SESSION_SECRET=replace-with-a-long-random-string
